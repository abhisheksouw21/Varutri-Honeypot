{
  "manifest_version": 3,
  "name": "Varutri Scam Shield",
  "version": "0.1.0",
  "description": "Analyze suspicious browser content with Varutri consumer APIs.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Varutri Scam Shield",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
